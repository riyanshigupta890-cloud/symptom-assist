# Required: Get your Groq API key from https://console.groq.com/
GROQ_API_KEY="your_groq_api_key_here"

# Optional: Gemini API key (only needed if using Gemini model path)
GEMINI_API_KEY="your_gemini_key_here_or_leave_blank"

# ── Semantic Cache (all optional, sensible defaults applied) ──────────────
# Cosine-similarity threshold for a cache hit (0.0–1.0, higher = stricter)
CACHE_SIMILARITY_THRESHOLD=0.92
# Time-to-live for cached entries in seconds (default: 3600 = 1 hour)
CACHE_TTL_SECONDS=3600
# Maximum number of cached entries before LRU eviction kicks in
CACHE_MAX_ENTRIES=500
